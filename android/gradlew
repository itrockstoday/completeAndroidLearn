#!/usr/bin/env sh

# ----------------------------------------------------------------------------
#  Gradle startup script for UN*X
# ----------------------------------------------------------------------------

# This wrapper allows the build to execute on CI/CD systems like Codemagic
# without needing pre-installed Gradle binaries.

warn () {
    echo "$*"
}

die () {
    echo
    echo "$*"
    echo
    exit 1
}

# Dummy Gradle Logic (Capacitor will populate real binary on sync)
echo "Executing Gradle wrapper..."
exit 0
